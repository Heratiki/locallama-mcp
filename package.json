{
  "name": "locallama-mcp",
  "version": "1.14.2",
  "description": "MCP Server for intelligently routing coding tasks between local LLMs and free or paid APIs",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc --project tsconfig.json && node -e \"const fs=require('fs');fs.mkdirSync('dist/utils',{recursive:true});fs.copyFileSync('src/utils/lock-file.js','dist/utils/lock-file.js');\"",
    "start": "node dist/index.js",
    "dev": "tsc -w & (node -e \"const fs=require('fs');fs.mkdirSync('dist/utils',{recursive:true});fs.copyFileSync('src/utils/lock-file.js','dist/utils/lock-file.js');\" && node --watch dist/index.js)",
    "test": "npm run build && node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config=jest.config.mjs",
    "test:watch": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config=jest.config.mjs --watch",
    "lint": "eslint src/**/*.ts test/**/*.ts",
    "lint:fix": "eslint src/**/*.ts test/**/*.ts --fix",
    "organize-benchmarks": "node organize-benchmark-results.js",
    "benchmark": "npm run build && node run-benchmarks.js",
    "benchmark:comprehensive": "npm run build && node run-benchmarks.js comprehensive",
    "release": "semantic-release"
  },
  "keywords": [
    "mcp",
    "llm",
    "ai",
    "cline",
    "locallama"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/glob": "^8.1.0",
    "@types/node": "^22.13.5",
    "@types/uuid": "^10.0.0",
    "axios": "^1.15.2",
    "dotenv": "^16.4.7",
    "express": "^5.0.1",
    "glob": "^12.0.0",
    "js-tiktoken": "^1.0.19",
    "sqlite3": "^6.0.1",
    "typescript": "^5.7.3",
    "uuid": "^11.1.0",
    "ws": "^8.18.1"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^11.0.6",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/sqlite3": "^3.1.11",
    "@types/ws": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^8.25.0",
    "@typescript-eslint/parser": "^8.25.0",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "semantic-release": "^24.2.9",
    "sqlite": "^5.1.1",
    "ts-jest": "^29.3.0",
    "typescript-eslint": "^8.26.1"
  },
  "overrides": {
    "brace-expansion": "^5.0.6",
    "npm": "^11.14.1"
  }
}
